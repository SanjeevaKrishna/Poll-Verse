<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dog Poll – PollVerse</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0a0a0f;
      --surface: #13131a;
      --border: #1e1e2e;
      --text: #f0f0fa;
      --muted: #6b6b8a;
      --accent: #f97316;  /* ← Change this per page */
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
      padding: 0;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
      z-index: 0;
    }

    .wrap {
      position: relative;
      z-index: 1;
      max-width: 640px;
      margin: 0 auto;
      padding: 48px 24px 80px;
    }

    .back {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: var(--muted);
      text-decoration: none;
      font-size: 14px;
      margin-bottom: 40px;
      transition: color 0.2s;
    }
    .back:hover { color: var(--text); }

    .poll-header { margin-bottom: 40px; }

    .poll-emoji {
      font-size: 64px;
      display: block;
      margin-bottom: 16px;
    }

    h1 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(28px, 5vw, 44px);
      font-weight: 800;
      letter-spacing: -1px;
      margin-bottom: 10px;
    }

    .poll-desc { color: var(--muted); font-size: 16px; line-height: 1.6; }

    /* Options */
    .options { display: flex; flex-direction: column; gap: 12px; margin-bottom: 32px; }

    .option {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 18px 20px;
      cursor: pointer;
      transition: border-color 0.2s, background 0.2s, transform 0.15s;
      position: relative;
      overflow: hidden;
      user-select: none;
    }

    .option:hover { border-color: color-mix(in srgb, var(--accent) 50%, transparent); transform: translateX(4px); }

    .option.selected {
      border-color: var(--accent);
      background: color-mix(in srgb, var(--accent) 8%, var(--surface));
    }

    .option-inner {
      display: flex;
      align-items: center;
      gap: 14px;
      position: relative;
      z-index: 1;
    }

    .option-emoji { font-size: 28px; flex-shrink: 0; }

    .option-label {
      font-size: 16px;
      font-weight: 500;
      flex: 1;
    }

    .option-check {
      width: 22px; height: 22px;
      border-radius: 50%;
      border: 2px solid var(--border);
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: border-color 0.2s, background 0.2s;
      font-size: 12px;
    }

    .option.selected .option-check {
      background: var(--accent);
      border-color: var(--accent);
    }

    /* Results bar */
    .option-bar {
      position: absolute;
      top: 0; left: 0; bottom: 0;
      background: color-mix(in srgb, var(--accent) 12%, transparent);
      width: 0%;
      transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
      border-radius: 14px;
      z-index: 0;
    }

    .option-pct {
      font-size: 13px;
      color: var(--accent);
      font-weight: 500;
      display: none;
    }

    /* Voted state */
    body.voted .option { cursor: default; }
    body.voted .option:hover { transform: none; }
    body.voted .option-pct { display: block; }

    /* Submit button */
    .btn {
      width: 100%;
      padding: 16px;
      background: var(--accent);
      color: #fff;
      font-family: 'Syne', sans-serif;
      font-size: 16px;
      font-weight: 700;
      border: none;
      border-radius: 14px;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.15s;
      letter-spacing: 0.02em;
    }
    .btn:hover { opacity: 0.9; transform: translateY(-1px); }
    .btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

    .voted-msg {
      text-align: center;
      padding: 20px;
      color: var(--muted);
      font-size: 14px;
      display: none;
    }

    body.voted .voted-msg { display: block; }
    body.voted .btn { display: none; }

    .total-votes {
      text-align: center;
      color: var(--muted);
      font-size: 13px;
      margin-top: 16px;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .wrap { animation: fadeUp 0.5s ease both; }
  </style>
</head>
<body>
<div class="wrap">
  <a class="back" href="../index.html">← All Polls</a>

  <div class="poll-header">
    <span class="poll-emoji" id="emoji"></span>
    <h1 id="title"></h1>
    <p class="poll-desc" id="desc"></p>
  </div>

  <div class="options" id="options"></div>
  <button class="btn" id="voteBtn" disabled>Select an option to vote</button>
  <div class="voted-msg">✅ Thanks for voting! Results are shown below.</div>
  <div class="total-votes" id="totalVotes"></div>
</div>

<script>
  // ← This is the POLL ID — change this to match which poll to load
  const POLL_SLUG = 'cats';

  let selected = null;
  let votes = {};
  let poll = null;

  // Load polls.json from root (one level up from /pages/)
  fetch('../polls.json')
    .then(r => r.json())
    .then(data => {
      poll = data.polls.find(p => p.slug === POLL_SLUG);
      if (!poll) return;

      // Apply accent color
      document.documentElement.style.setProperty('--accent', poll.color);
      document.title = poll.title + ' – PollVerse';
      document.getElementById('emoji').textContent = poll.emoji;
      document.getElementById('title').textContent = poll.title;
      document.getElementById('desc').textContent = poll.description;

      // Load saved votes from localStorage
      const saved = localStorage.getItem('votes_' + POLL_SLUG);
      votes = saved ? JSON.parse(saved) : {};
      if (!Object.keys(votes).length) {
        poll.options.forEach(o => votes[o.id] = Math.floor(Math.random() * 40 + 5));
      }

      renderOptions();

      // If already voted
      const myVote = localStorage.getItem('myvote_' + POLL_SLUG);
      if (myVote) {
        selected = myVote;
        document.body.classList.add('voted');
        showResults();
        document.querySelectorAll('.option').forEach(el => {
          if (el.dataset.id === myVote) el.classList.add('selected');
        });
      }
    });

  function renderOptions() {
    const container = document.getElementById('options');
    poll.options.forEach(opt => {
      const el = document.createElement('div');
      el.className = 'option';
      el.dataset.id = opt.id;
      el.innerHTML = `
        <div class="option-bar" data-bar="${opt.id}"></div>
        <div class="option-inner">
          <span class="option-emoji">${opt.emoji}</span>
          <span class="option-label">${opt.label}</span>
          <span class="option-pct" data-pct="${opt.id}">0%</span>
          <span class="option-check" data-check="${opt.id}">✓</span>
        </div>
      `;
      el.addEventListener('click', () => selectOption(opt.id));
      container.appendChild(el);
    });
  }

  function selectOption(id) {
    if (document.body.classList.contains('voted')) return;
    selected = id;
    document.querySelectorAll('.option').forEach(el => {
      el.classList.toggle('selected', el.dataset.id === id);
    });
    const btn = document.getElementById('voteBtn');
    btn.disabled = false;
    btn.textContent = 'Cast My Vote →';
  }

  document.getElementById('voteBtn').addEventListener('click', () => {
    if (!selected) return;
    votes[selected] = (votes[selected] || 0) + 1;
    localStorage.setItem('votes_' + POLL_SLUG, JSON.stringify(votes));
    localStorage.setItem('myvote_' + POLL_SLUG, selected);
    document.body.classList.add('voted');
    showResults();
  });

  function showResults() {
    const total = Object.values(votes).reduce((a, b) => a + b, 0);
    poll.options.forEach(opt => {
      const count = votes[opt.id] || 0;
      const pct = total ? Math.round((count / total) * 100) : 0;
      const bar = document.querySelector(`[data-bar="${opt.id}"]`);
      const pctEl = document.querySelector(`[data-pct="${opt.id}"]`);
      if (bar) setTimeout(() => bar.style.width = pct + '%', 50);
      if (pctEl) pctEl.textContent = pct + '%';
    });
    document.getElementById('totalVotes').textContent = total + ' total votes';
  }
</script>
</body>
</html>
